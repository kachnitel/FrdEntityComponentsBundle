<?xml version="1.0"?>
<ruleset name="PHPMD rule set for Entity Components Bundle"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0
                     http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="
                     http://pmd.sf.net/ruleset_xml_schema.xsd">
    <description>
        Custom ruleset for PHPMD - Entity Components Bundle
    </description>

    <!-- Custom rules -->
    <rule ref="rulesets/naming.xml/ShortVariable">
        <properties>
            <property name="exceptions" value="i,id,em,qb,po,io,a,b,to" />
        </properties>
    </rule>

    <rule ref="rulesets/naming.xml/LongVariable">
        <properties>
            <property name="maximum" value="24"/>
            <property name="subtract-suffixes" value="Repo,StateMachine,Workflow" />
        </properties>
    </rule>

    <!-- unusedcode,codesize,naming,design,controversial -->
    <rule ref="rulesets/codesize.xml" />
    <rule ref="rulesets/unusedcode.xml" />
    <rule ref="rulesets/naming.xml" >
        <exclude name="ShortVariable" />
        <exclude name="LongVariable" />
    </rule>

    <!--
        Design rules
          — CouplingBetweenObjects threshold raised from the default 13 to 16.

        Rationale: PHP 8 attributes (#[AsLiveComponent], #[LiveProp], #[LiveAction],
        #[LiveArg], #[ExposeInTemplate]) are real PHP classes.

        PHPMD does not yet support pattern-based exclusions for specific classes
        (https://github.com/phpmd/phpmd/issues/637); raising the threshold is the
        only ruleset-level option available.
    -->
    <rule ref="rulesets/design.xml">
        <exclude name="CouplingBetweenObjects" />
    </rule>
    <rule ref="rulesets/design.xml/CouplingBetweenObjects">
        <properties>
            <property name="minimum" value="16"
                      description="Raised from 13: PHP 8 attribute classes
                                   (LiveProp, LiveAction, LiveArg, AsLiveComponent,
                                   ExposeInTemplate) each count as a dependency." />
        </properties>
    </rule>

    <rule ref="rulesets/controversial.xml" />
</ruleset>
