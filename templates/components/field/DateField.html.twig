{#
 # DateField - inline date/datetime/time editor.
 #   this.editMode        - bool
 #   this.canEdit         - bool   (#[ExposeInTemplate] on canEdit())
 #   this.dateValue       - ?string
 #   this.formFieldConfig - array  ({type, required})
 #   this.label           - string
 #   errorMessage         - string  (LiveProp — non-empty when last save failed validation)
 #   saveSuccess          - bool    (LiveProp — true after a successful flush)
 #}
<div {{ attributes }}>
    {% if this.editMode and this.canEdit %}
        <input
            type="{{ this.formFieldConfig.type }}"
            class="form-control form-control-sm{% if errorMessage %} is-invalid{% endif %}"
            data-model="dateValue"
            value="{{ this.dateValue }}"
            aria-label="{{ this.label }}"
            autofocus
            {% if this.formFieldConfig.required %}required{% endif %}
        />
        {% if errorMessage %}
            <div class="invalid-feedback d-block">{{ errorMessage }}</div>
        {% endif %}
        <button type="button" data-action="live#action" data-live-action-param="save"
            class="btn btn-sm btn-success">Save</button>
        <button type="button" data-action="live#action" data-live-action-param="cancelEdit"
            class="btn btn-sm btn-secondary">Cancel</button>
    {% else %}
        <span class="field-editable-cell">
            {% include '@KachnitelEntityComponents/components/field/_display.html.twig' %}
            {% if saveSuccess %}
                <span class="inline-edit-saved text-success small" aria-label="Saved">✓</span>
            {% endif %}
            {% if this.canEdit %}
                <button type="button" class="field-edit-trigger"
                    data-action="live#action" data-live-action-param="activateEditing"
                    title="Edit {{ this.label }}">✎</button>
            {% endif %}
        </span>
    {% endif %}
</div>
