{#
 # Default read-only display for inline-edit field components.
 #
 # Override in your app:
 #   templates/bundles/KachnitelEntityComponents/components/field/_display.html.twig
 #
 # Type dispatch order:
 #   1. null
 #   2. iterable (array, Collection)
 #   3. BackedEnum  — has .value, no .id
 #   4. UnitEnum    — has .name, no .value, no .id
 #   5. Doctrine entity / any object with .id
 #         → __toString() → .name → .label → .title → "#ID" fallback
 #   6. bool → "Yes" / "No"
 #   7. scalar (int / float / string)
 #}
{% if value is null %}
    <span class="text-muted">—</span>
{% elseif value is iterable %}
    {{ value|join(', ') }}
{% elseif value.value is defined and value.id is not defined %}
    {# BackedEnum #}
    {{ value.value }}
{% elseif value.name is defined and value.value is not defined and value.id is not defined %}
    {# UnitEnum #}
    {{ value.name }}
{% elseif value.id is defined %}
    {# Doctrine entity or any identified object — never do bare {{ value }} here #}
    {% if value.__toString is defined %}
        {{ value }}
    {% elseif value.name is defined %}
        {{ value.name }}
    {% elseif value.label is defined %}
        {{ value.label }}
    {% elseif value.title is defined %}
        {{ value.title }}
    {% else %}
        #{{ value.id }}
    {% endif %}
{% elseif value is same as(true) or value is same as(false) %}
    {{ value ? 'Yes' : 'No' }}
{% else %}
    {{ value }}
{% endif %}
