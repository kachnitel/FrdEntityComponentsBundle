{#
  SelectRelationship - Reusable select component for entity relationships and enums.

  Required:
    entity: object - The entity containing the property
    property: string - The property name to edit

  Optional:
    options: SelectRelationshipOptions - Configuration DTO (see class docblock for all props)

  Nested attributes (applied directly to inner elements):
    select:* - Attributes for the <select> element (e.g., select:class="compact")
    static:* - Attributes for the static display <span> (e.g., static:class="text-muted")

  Usage:
    - Basic usage
    <twig:K:Entity:SelectRelationship :entity="order" property="region" />

    - With options DTO
    <twig:K:Entity:SelectRelationship
      :entity="order"
      property="region"
      :options="new SelectRelationshipOptions(
          role: 'ROLE_ORDER_REGION_EDIT',
          placeholder: '- Region -',
          select:class='d-block mb-1 bg-warning compact',
      )"
    />

    - With filter
    <twig:K:Entity:SelectRelationship
      :entity="order"
      property="assignedTo"
      :options="new SelectRelationshipOptions(filter: { active: true })"
    />

    - With custom repository method
    <twig:K:Entity:SelectRelationship
      :entity="order"
      property="assignedTo"
      :options="new SelectRelationshipOptions(
          repositoryMethod: 'findByRoles',
          repositoryArgs: [['ROLE_TERRITORY_MANAGER']],
      )"
    />
#}

{% set canEdit = (options.role is null or is_granted(options.role)) and not options.disabled and not this.entityObject.isDeleted|default(false) %}
{% set canView = options.viewRole is null or is_granted(options.viewRole) %}

{% if canEdit %}
  <div{{ attributes }}>
    {% if options.label %}
      <label class="form-label">{{ options.label }}</label>
    {% endif %}
    <select{{ attributes.nested('select') }} data-model="value">
      <option
        value=""
        {% if options.disableEmpty %}disabled{% endif %}
        {% if value is null %}selected{% endif %}
      >
        {{ options.placeholder }}
      </option>
      {% for option in this.options %}
        <option
          value="{{ this.getOptionValue(option) }}"
          {% if this.isSelected(option) %}selected{% endif %}
        >
          {{ this.getOptionLabel(option) }}
        </option>
      {% endfor %}
    </select>
  </div>
{% elseif canView %}
  <span{{ attributes }}{{ attributes.nested('static') }}>
    {% if options.label %}
      <span class="text-muted">{{ options.label }}: </span>
    {% endif %}
    {{ this.currentDisplayValue|capitalize }}
  </span>
{% endif %}
